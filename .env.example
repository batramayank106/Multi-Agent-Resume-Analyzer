# Hugging Face Inference API (get token at https://huggingface.co/settings/tokens)
HF_API_KEY=hf_your_api_key_here
HF_DEFAULT_MODEL=Qwen/Qwen2.5-7B-Instruct

# Groq (fast cloud inference, free tier — get key at https://console.groq.com/keys)
# Groq is tried FIRST before any other provider when configured.
# GROQ_API_KEY=gsk_your_key_here
# GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# Ollama (local inference fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_GPU_LAYERS=0

# Database
DATABASE_URL=sqlite+aiosqlite:///./cv_chacha.db

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# App Settings
APP_NAME=CV Chacha
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_FALLBACK_MODEL=all-MiniLM-L6-v2

# OCR (optional — set if Tesseract is not in PATH)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# JWT Authentication (generate a secret with: openssl rand -hex 32)
JWT_SECRET=your-secure-random-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Super Admin (created on startup — CHANGE these after first login)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe123!

# Encryption (generate a key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=
